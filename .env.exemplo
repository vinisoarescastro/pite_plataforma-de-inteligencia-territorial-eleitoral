# Banco de Dados (desenvolvimento local)
# Substitua usuario, senha e porta conforme sua instalação do PostgreSQL
DATABASE_URL=postgresql://usuario:senha@localhost:5432/pite

# Segurança JWT
# Gere uma chave segura com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_CHAVE_SECRETA=troque-por-uma-chave-segura-gerada-aleatoriamente
JWT_ALGORITMO=HS256
JWT_EXPIRACAO_MINUTOS=15
JWT_REFRESH_EXPIRACAO_DIAS=7

# API
AMBIENTE=desenvolvimento
DEBUG=true
PORTA=8000
